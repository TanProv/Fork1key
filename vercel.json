{
    "version": 2,
    "name": "fork1key-batch-verifier",
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1",
            "continue": true
        },
        {
            "src": "/styles.css",
            "dest": "/public/styles.css",
            "continue": true
        },
        {
            "src": "/guide-content.html",
            "dest": "/public/guide-content.html",
            "continue": true
        },
        {
            "src": "/api/(.*)",
            "dest": "/server.js"
        },
        {
            "src": "/admin/(.*)",
            "dest": "/server.js"
        },
        {
            "src": "/(.*)",
            "dest": "/server.js"
        }
    ]
}